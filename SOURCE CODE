
#include <WiFi.h>
#include <HTTPClient.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include "DHT.h"
#include <TinyGPSPlus.h>
#include "esp_wifi.h"
#include <SPI.h>
#include <MFRC522.h>

// ===== CONFIG =====
const char* WIFI_SSID = "Nothing";        // set your SSID
const char* WIFI_PASS = "12345678";       // set your password
const char* APIKEY = "DTLT0DXECX6Z1QQN";  // ThingSpeak write API key

const unsigned long UPDATE_INTERVAL = 20000UL; // >= 15000ms for ThingSpeak

// ===== PINS & HARDWARE =====
#define DHTPIN 12
#define DHTTYPE DHT11

LiquidCrystal_I2C lcd(0x27, 16, 2);
DHT dht(DHTPIN, DHTTYPE);

// GPS TinyGPSPlus (UART2)
TinyGPSPlus gps;
HardwareSerial GPSSerial(2);
const int GPS_RX = 16; // GPS TX -> ESP RX2
const int GPS_TX = 17; // GPS RX -> ESP TX2

// RFID (MFRC522) SPI pins & config
const uint8_t RST_PIN = 4;
const uint8_t SS_PIN  = 5;  // SDA pin on RC522
// SPI pins used with SPI.begin(SCK, MISO, MOSI)
const int SPI_SCK  = 18;
const int SPI_MISO = 19;
const int SPI_MOSI = 23;
MFRC522 mfrc522(SS_PIN, RST_PIN);

// runtime
unsigned long lastUpdate = 0;
String lastUID = "None";

// --------- Helpers ----------
String uidToString(const MFRC522::Uid &uid) {
  String s = "";
  for (byte i = 0; i < uid.size; i++) {
    byte b = uid.uidByte[i];
    if (b < 0x10) s += "0";
    s += String(b, HEX);
  }
  s.toUpperCase();
  return s;
}

String urlEncode(const String &str) {
  String encoded = "";
  const char *hex = "0123456789ABCDEF";
  for (size_t i = 0; i < str.length(); ++i) {
    char c = str[i];
    if (('a' <= c && c <= 'z') || ('A' <= c && c <= 'Z') || ('0' <= c && c <= '9') ||
        c == '-' || c == '_' || c == '.' || c == '~') {
      encoded += c;
    } else if (c == ' ') {
      encoded += '+';
    } else {
      encoded += '%';
      encoded += hex[(c >> 4) & 0xF];
      encoded += hex[c & 0xF];
    }
  }
  return encoded;
}

void lcdPrintFixed(int col, int row, const String &text, int width=16) {
  lcd.setCursor(col, row);
  String out = text;
  if ((int)out.length() < width) {
    for (int i = out.length(); i < width; ++i) out += ' ';
  } else if ((int)out.length() > width) {
    out = out.substring(0, width);
  }
  lcd.print(out);
}

// --------- Setup ----------
void setup() {
  Serial.begin(115200);
  delay(300);
  Serial.println("\n=== SYSTEM START ===");

  // LCD init
  Wire.begin(21, 22);
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcdPrintFixed(0,0,"System Start...",16);
  lcdPrintFixed(0,1,"Init...",16);

  // DHT
  dht.begin();

  // GPS UART2
  GPSSerial.begin(9600, SERIAL_8N1, GPS_RX, GPS_TX);

  // RFID SPI init: explicitly specify SPI pins for ESP32
  SPI.begin(SPI_SCK, SPI_MISO, SPI_MOSI);
  pinMode(SS_PIN, OUTPUT);    // recommended to declare SS pin mode
  pinMode(RST_PIN, OUTPUT);   // recommended to declare RST pin mode
  digitalWrite(SS_PIN, HIGH); // deselect
  digitalWrite(RST_PIN, HIGH);
  delay(10);
  mfrc522.PCD_Init();         // initialize MFRC522
  delay(50);
  Serial.println("RFID initialized");

  // WiFi connect (short timeout)
  WiFi.mode(WIFI_STA);
  esp_wifi_set_ps(WIFI_PS_NONE);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  lcdPrintFixed(0,0,"WiFi Connecting",16);
  int retry = 0;
  while (WiFi.status() != WL_CONNECTED && retry < 40) {
    delay(300);
    Serial.print(".");
    retry++;
  }
  lcd.clear();
  if (WiFi.status()==WL_CONNECTED) {
    Serial.println("\nWiFi connected");
    lcdPrintFixed(0,0,"WiFi OK",16);
  } else {
    Serial.println("\nWiFi NOT connected");
    lcdPrintFixed(0,0,"WiFi FAILED",16);
  }

  lastUpdate = millis();
  delay(200);
}

// --------- Main loop ----------
void loop() {
  // Feed GPS bytes to parser continuously
  while (GPSSerial.available()) {
    char c = (char)GPSSerial.read();
    gps.encode(c);
  }

  // Handle RFID: robust check + stop crypto
  if (mfrc522.PICC_IsNewCardPresent()) {
    if (mfrc522.PICC_ReadCardSerial()) {
      String uid = uidToString(mfrc522.uid);
      lastUID = uid;
      Serial.print("RFID: New UID = ");
      Serial.println(uid);

      // If you plan to authenticate/communicate, stop crypto after use:
      mfrc522.PICC_HaltA();          // Halt PICC
      mfrc522.PCD_StopCrypto1();     // Stop encryption on PCD
    } else {
      Serial.println("RFID: PICC_ReadCardSerial() failed");
    }
  }

  // Read DHT (with quick retries)
  float tempC = dht.readTemperature();
  float hum = dht.readHumidity();
  if (isnan(tempC) || isnan(hum)) {
    delay(100);
    tempC = dht.readTemperature();
    hum = dht.readHumidity();
    if (isnan(tempC) || isnan(hum)) {
      delay(100);
      tempC = dht.readTemperature();
      hum = dht.readHumidity();
    }
  }
  bool haveTemp = !isnan(tempC);
  bool haveHum  = !isnan(hum);

  // GPS parsed values (TinyGPSPlus)
  bool gpsFix = gps.location.isValid();
  double lat = gpsFix ? gps.location.lat() : 0.0;
  double lon = gpsFix ? gps.location.lng() : 0.0;
  int sats = gps.satellites.isValid() ? gps.satellites.value() : 0;
  bool timeValid = gps.time.isValid();
  bool dateValid = gps.date.isValid();

  // Update LCD: line0 = Temp & Hum, line1 = UID or GPS short
  String line0;
  if (haveTemp) line0 = "T:" + String(tempC,1) + "C ";
  else line0 = "T:--.-C ";
  if (haveHum) line0 += "H:" + String(hum,0);
  else line0 += "H:--";
  lcdPrintFixed(0,0,line0,16);

  String line1;
  if (lastUID != "None") line1 = "ID:" + lastUID;
  else if (gpsFix) line1 = "G:" + String(lat,2) + "," + String(lon,2);
  else line1 = "Sats:" + String(sats);
  lcdPrintFixed(0,1,line1,16);

  // Print verbose debug to Serial (including TinyGPSPlus parsed fields)
  Serial.println("----- SENSOR DATA -----");
  Serial.print("Temp (C): "); Serial.println(haveTemp ? String(tempC,2) : String("N/A"));
  Serial.print("Humidity (%): "); Serial.println(haveHum ? String(hum,2) : String("N/A"));
  Serial.print("RFID last UID: "); Serial.println(lastUID);
  Serial.print("GPS Fix: "); Serial.println(gpsFix ? "YES" : "NO");
  Serial.print("Satellites: "); Serial.println(sats);

  if (gpsFix) {
    Serial.print("Latitude:  "); Serial.println(String(lat,6));
    Serial.print("Longitude: "); Serial.println(String(lon,6));
    Serial.print("Fix age (ms): "); Serial.println(gps.location.age());
  } else {
    Serial.println("Location: Not valid yet");
  }

  if (timeValid) {
    Serial.print("Time (UTC): ");
    if (gps.time.hour() < 10) Serial.print('0');
    Serial.print(gps.time.hour()); Serial.print(':');
    if (gps.time.minute() < 10) Serial.print('0');
    Serial.print(gps.time.minute()); Serial.print(':');
    if (gps.time.second() < 10) Serial.print('0');
    Serial.println(gps.time.second());
  } else Serial.println("Time: Not valid");

  if (dateValid) {
    Serial.print("Date (D/M/Y): ");
    Serial.print(gps.date.day()); Serial.print('/');
    Serial.print(gps.date.month()); Serial.print('/');
    Serial.println(gps.date.year());
  } else Serial.println("Date: Not valid");

  if (gps.hdop.isValid()) {
    Serial.print("HDOP: "); Serial.println(gps.hdop.hdop());
  }
  if (gps.altitude.isValid()) {
    Serial.print("Altitude (m): "); Serial.println(gps.altitude.meters());
  }
  if (gps.speed.isValid()) {
    Serial.print("Speed (km/h): "); Serial.println(gps.speed.kmph());
  }
  Serial.println("-----------------------");

  // ThingSpeak upload mapping:
  // field1 = temperature, field2 = humidity, field3 = longitude, field4 = latitude
  unsigned long now = millis();
  if (now - lastUpdate >= UPDATE_INTERVAL) {
    lastUpdate = now;
    if (WiFi.status() == WL_CONNECTED) {
      String lonStr = gpsFix ? String(lon,6) : String("");
      String latStr = gpsFix ? String(lat,6) : String("");
      String url = String("http://api.thingspeak.com/update?api_key=") + APIKEY
        + "&field1=" + (haveTemp ? String(tempC,2) : String(""))
        + "&field2=" + (haveHum ? String(hum,2) : String(""))
        + "&field3=" + urlEncode(lonStr)
        + "&field4=" + urlEncode(latStr);

      Serial.println("ThingSpeak GET:");
      Serial.println(url);

      HTTPClient http;
      http.begin(url);
      int httpCode = http.GET();
      Serial.print("ThingSpeak HTTP code: ");
      Serial.println(httpCode);
      if (httpCode > 0) {
        String payload = http.getString();
        Serial.println("ThingSpeak response:");
        Serial.println(payload);
      } else {
        Serial.println("ThingSpeak request failed");
      }
      http.end();
    } else {
      Serial.println("WiFi not connected — skipping upload");
    }
  }

  delay(700); // adjust loop timing as desired
}
